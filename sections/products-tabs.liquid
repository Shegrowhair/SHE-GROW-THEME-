{% comment %}
  sections/product-tabs.liquid
  She Grow Hair Co. — Product Detail Tabs
  (Description, How to Use, Ingredients)
  Online Store 2.0 compatible
{% endcomment %}

<style>
  /* =============================================
     PRODUCT TABS — She Grow Hair Co.
     ============================================= */
  .product-tabs {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .product-tabs__nav {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 0;
  }

  .product-tabs__nav::-webkit-scrollbar { display: none; }

  .product-tabs__tab {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(44,26,14,0.5);
    padding: var(--space-4) var(--space-6);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color var(--transition-base), border-color var(--transition-base);
    white-space: nowrap;
    position: relative;
    bottom: -1px;
  }

  .product-tabs__tab:hover { color: var(--color-foreground); }

  .product-tabs__tab.is-active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    font-weight: 500;
  }

  .product-tabs__panels {
    padding: var(--space-10) 0;
  }

  .product-tabs__panel {
    display: none;
  }

  .product-tabs__panel.is-active {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    animation: tabFadeIn 250ms ease;
  }

  @media (min-width: 768px) {
    .product-tabs__panel.is-active {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
    }
  }

  @keyframes tabFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    @keyframes tabFadeIn { from { opacity: 0; } to { opacity: 1; } }
  }

  /* Description panel */
  .tab-description__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.85;
    color: rgba(44,26,14,0.75);
  }

  .tab-description__body p + p  { margin-top: var(--space-4); }
  .tab-description__body h3,
  .tab-description__body h4 {
    font-family: var(--font-display);
    font-weight: 400;
    color: var(--color-foreground);
    margin: var(--space-6) 0 var(--space-2);
  }
  .tab-description__body h3 { font-size: var(--text-xl); }
  .tab-description__body h4 { font-size: var(--text-lg); }
  .tab-description__body ul {
    margin: var(--space-3) 0 var(--space-3) var(--space-4);
    list-style: disc;
  }
  .tab-description__body li { margin-bottom: var(--space-1); }
  .tab-description__body strong { font-weight: 500; color: var(--color-foreground); }
  .tab-description__body a {
    color: var(--color-primary);
    border-bottom: 1px solid currentColor;
  }

  /* Product highlights sidebar */
  .tab-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .highlight-card {
    padding: var(--space-5) var(--space-5);
    background-color: var(--color-background);
    border-left: 3px solid var(--color-secondary);
  }

  .highlight-card__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-1);
    display: block;
  }

  .highlight-card__value {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: rgba(44,26,14,0.75);
    line-height: 1.6;
  }

  /* How to use panel */
  .tab-how-to__steps {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .tab-how-to__step {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .tab-how-to__num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #fff;
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .tab-how-to__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(44,26,14,0.75);
    flex: 1;
  }

  .tab-how-to__tip {
    background-color: var(--color-background);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-4) var(--space-5);
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: rgba(44,26,14,0.7);
    line-height: 1.7;
  }

  .tab-how-to__tip strong {
    font-weight: 500;
    color: var(--color-accent);
    display: block;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-1);
  }

  /* Ingredients panel */
  .tab-ingredients__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    color: rgba(44,26,14,0.65);
    line-height: 1.75;
    margin-bottom: var(--space-6);
  }

  .ingredients-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ingredient-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .ingredient-row:last-child { border-bottom: none; }

  .ingredient-row__name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.3;
  }

  .ingredient-row__benefit {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: rgba(44,26,14,0.65);
    line-height: 1.6;
  }

  .ingredient-row__benefit em {
    font-style: normal;
    font-weight: 500;
    color: var(--color-accent);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 2px;
  }

  .tab-ingredients__full {
    margin-top: var(--space-8);
    padding: var(--space-5);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
  }

  .tab-ingredients__full-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(44,26,14,0.5);
    margin-bottom: var(--space-2);
    display: block;
  }

  .tab-ingredients__full-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(44,26,14,0.55);
    letter-spacing: 0.02em;
  }
</style>

<section class="product-tabs" id="ProductTabs-{{ section.id }}">
  <div class="page-width">

    <!-- Tab nav -->
    <nav class="product-tabs__nav" role="tablist" aria-label="Product details">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <button
            class="product-tabs__tab{% if forloop.first %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="TabPanel-{{ section.id }}-{{ forloop.index }}"
            id="TabBtn-{{ section.id }}-{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.tab_label }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <!-- Tab panels -->
    <div class="product-tabs__panels">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <div
            class="product-tabs__panel{% if forloop.first %} is-active{% endif %}"
            id="TabPanel-{{ section.id }}-{{ forloop.index }}"
            role="tabpanel"
            aria-labelledby="TabBtn-{{ section.id }}-{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {%- case block.settings.tab_type -%}

              {%- when 'description' -%}
                <div class="tab-description__body">
                  {{ product.description }}
                </div>
                <div class="tab-highlights">
                  {%- if product.tags contains 'sulfate-free' or block.settings.show_highlights -%}
                    <div class="highlight-card">
                      <span class="highlight-card__label">Good for</span>
                      <p class="highlight-card__value">{{ block.settings.good_for | default: 'All textured hair types — curly, coily, wavy, loc'd' }}</p>
                    </div>
                    <div class="highlight-card">
                      <span class="highlight-card__label">Free from</span>
                      <p class="highlight-card__value">{{ block.settings.free_from | default: 'Sulfates · Parabens · Silicones · Mineral Oil' }}</p>
                    </div>
                    <div class="highlight-card">
                      <span class="highlight-card__label">Best used</span>
                      <p class="highlight-card__value">{{ block.settings.best_used | default: '1–2 times per week as part of your wash day routine' }}</p>
                    </div>
                  {%- endif -%}
                </div>

              {%- when 'how_to_use' -%}
                {%- if product.metafields.custom.how_to_use != blank -%}
                  <div class="tab-description__body">{{ product.metafields.custom.how_to_use }}</div>
                {%- else -%}
                  <ol class="tab-how-to__steps" aria-label="How to use">
                    {%- assign steps = block.settings.steps | newline_to_br | split: '<br />' -%}
                    {%- for step in steps -%}
                      {%- if step != blank -%}
                        <li class="tab-how-to__step">
                          <span class="tab-how-to__num" aria-hidden="true">{{ forloop.index }}</span>
                          <p class="tab-how-to__text">{{ step | strip }}</p>
                        </li>
                      {%- endif -%}
                    {%- endfor -%}
                  </ol>
                {%- endif -%}
                {%- if block.settings.pro_tip != blank -%}
                  <div class="tab-how-to__tip">
                    <strong>She Grow Tip</strong>
                    {{ block.settings.pro_tip }}
                  </div>
                {%- endif -%}

              {%- when 'ingredients' -%}
                {%- if product.metafields.custom.ingredients_intro != blank -%}
                  <p class="tab-ingredients__intro">{{ product.metafields.custom.ingredients_intro }}</p>
                {%- else -%}
                  <p class="tab-ingredients__intro">{{ block.settings.ingredients_intro | default: 'Every ingredient in this formula earns its place. Here is what is doing the real work.' }}</p>
                {%- endif -%}

                <div>
                  <div class="ingredients-list">
                    {%- for i in (1..6) -%}
                      {%- assign name_key   = 'ingredient_' | append: i | append: '_name' -%}
                      {%- assign role_key   = 'ingredient_' | append: i | append: '_role' -%}
                      {%- assign benefit_key = 'ingredient_' | append: i | append: '_benefit' -%}
                      {%- if block.settings[name_key] != blank -%}
                        <div class="ingredient-row">
                          <span class="ingredient-row__name">{{ block.settings[name_key] }}</span>
                          <div class="ingredient-row__benefit">
                            {%- if block.settings[role_key] != blank -%}
                              <em>{{ block.settings[role_key] }}</em>
                            {%- endif -%}
                            {{ block.settings[benefit_key] }}
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>

                  {%- if product.metafields.custom.full_ingredients != blank or block.settings.full_ingredients != blank -%}
                    <div class="tab-ingredients__full">
                      <span class="tab-ingredients__full-label">Full Ingredient List (INCI)</span>
                      <p class="tab-ingredients__full-text">
                        {{ product.metafields.custom.full_ingredients | default: block.settings.full_ingredients }}
                      </p>
                    </div>
                  {%- endif -%}
                </div>

            {%- endcase -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function() {
    var tabs   = document.querySelectorAll('#ProductTabs-{{ section.id }} .product-tabs__tab');
    var panels = document.querySelectorAll('#ProductTabs-{{ section.id }} .product-tabs__panel');

    tabs.forEach(function(tab, i) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) {
          t.classList.remove('is-active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(function(p) { p.classList.remove('is-active'); });

        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        if (panels[i]) panels[i].classList.add('is-active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Product Tabs",
  "tag": "section",
  "class": "section-product-tabs",
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Description"
        },
        {
          "type": "select",
          "id": "tab_type",
          "label": "Tab content type",
          "options": [
            { "value": "description",  "label": "Product description" },
            { "value": "how_to_use",   "label": "How to use" },
            { "value": "ingredients",  "label": "Ingredients" }
          ],
          "default": "description"
        },
        {
          "type": "header",
          "content": "Description tab settings"
        },
        {
          "type": "checkbox",
          "id": "show_highlights",
          "label": "Show highlights sidebar",
          "default": true
        },
        {
          "type": "text",
          "id": "good_for",
          "label": "Good for",
          "default": "All textured hair types — curly, coily, wavy, loc'd"
        },
        {
          "type": "text",
          "id": "free_from",
          "label": "Free from",
          "default": "Sulfates · Parabens · Silicones · Mineral Oil"
        },
        {
          "type": "text",
          "id": "best_used",
          "label": "Best used",
          "default": "1–2 times per week as part of your wash day routine"
        },
        {
          "type": "header",
          "content": "How to use tab settings"
        },
        {
          "type": "textarea",
          "id": "steps",
          "label": "Steps (one per line)",
          "default": "Wet hair thoroughly.\nApply to scalp and work into a lather.\nMassage for 60 seconds.\nRinse completely.\nFollow with conditioner."
        },
        {
          "type": "textarea",
          "id": "pro_tip",
          "label": "She Grow Tip",
          "default": "For best results, let your scalp massage go for a full 60 seconds. Circulation is everything."
        },
        {
          "type": "header",
          "content": "Ingredients tab settings"
        },
        {
          "type": "textarea",
          "id": "ingredients_intro",
          "label": "Intro text",
          "default": "Every ingredient in this formula earns its place. Here is what is doing the real work."
        },
        { "type": "text", "id": "ingredient_1_name",    "label": "Ingredient 1 name",    "default": "Cherry Extract" },
        { "type": "text", "id": "ingredient_1_role",    "label": "Ingredient 1 role",    "default": "Antioxidant Detoxifier" },
        { "type": "textarea", "id": "ingredient_1_benefit", "label": "Ingredient 1 benefit", "default": "Draws out scalp buildup and protects follicles from oxidative stress." },
        { "type": "text", "id": "ingredient_2_name",    "label": "Ingredient 2 name",    "default": "Jamaican Black Castor Oil" },
        { "type": "text", "id": "ingredient_2_role",    "label": "Ingredient 2 role",    "default": "Growth & Seal" },
        { "type": "textarea", "id": "ingredient_2_benefit", "label": "Ingredient 2 benefit", "default": "Thickens strands, seals the cuticle, and supports edge growth." },
        { "type": "text", "id": "ingredient_3_name",    "label": "Ingredient 3 name",    "default": "Aloe Vera" },
        { "type": "text", "id": "ingredient_3_role",    "label": "Ingredient 3 role",    "default": "Hydration & Soothing" },
        { "type": "textarea", "id": "ingredient_3_benefit", "label": "Ingredient 3 benefit", "default": "Calms scalp inflammation and delivers instant, weightless moisture." },
        { "type": "text", "id": "ingredient_4_name",    "label": "Ingredient 4 name",    "default": "Rosemary Oil" },
        { "type": "text", "id": "ingredient_4_role",    "label": "Ingredient 4 role",    "default": "Follicle Stimulant" },
        { "type": "textarea", "id": "ingredient_4_benefit", "label": "Ingredient 4 benefit", "default": "Clinically studied to stimulate follicle activity and improve density." },
        { "type": "text", "id": "ingredient_5_name",    "label": "Ingredient 5 name" },
        { "type": "text", "id": "ingredient_5_role",    "label": "Ingredient 5 role" },
        { "type": "textarea", "id": "ingredient_5_benefit", "label": "Ingredient 5 benefit" },
        { "type": "text", "id": "ingredient_6_name",    "label": "Ingredient 6 name" },
        { "type": "text", "id": "ingredient_6_role",    "label": "Ingredient 6 role" },
        { "type": "textarea", "id": "ingredient_6_benefit", "label": "Ingredient 6 benefit" },
        {
          "type": "textarea",
          "id": "full_ingredients",
          "label": "Full INCI ingredient list",
          "info": "The full technical ingredient list. Leave blank to hide."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Tabs",
      "blocks": [
        { "type": "tab", "settings": { "tab_label": "Description",  "tab_type": "description"  } },
        { "type": "tab", "settings": { "tab_label": "How to Use",   "tab_type": "how_to_use"   } },
        { "type": "tab", "settings": { "tab_label": "Ingredients",  "tab_type": "ingredients"  } }
      ]
    }
  ]
}
{% endschema %}


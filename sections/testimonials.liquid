{% comment %}
  sections/testimonials.liquid
  She Grow Hair Co. — Customer Reviews / Testimonials
  Online Store 2.0 compatible
{% endcomment %}

<style>
  /* =============================================
     TESTIMONIALS — She Grow Hair Co.
     ============================================= */
  .testimonials {
    background-color: {{ section.settings.background == 'dark' ? 'var(--color-foreground)' : 'var(--color-surface)' }};
    overflow: hidden;
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .testimonials__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: {% if section.settings.background == 'dark' %}#fff{% else %}var(--color-foreground){% endif %};
    line-height: 1.1;
    margin-bottom: var(--space-3);
  }

  .testimonials__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.55){% else %}rgba(44,26,14,0.55){% endif %};
    max-width: 44ch;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Aggregate rating bar */
  .testimonials__aggregate {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
  }

  .aggregate-score {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 300;
    color: {% if section.settings.background == 'dark' %}#fff{% else %}var(--color-foreground){% endif %};
    line-height: 1;
  }

  .aggregate-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .aggregate-count {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.5){% else %}rgba(44,26,14,0.5){% endif %};
    letter-spacing: 0.06em;
  }

  /* Cards carousel */
  .testimonials__track-wrap {
    position: relative;
    overflow: hidden;
  }

  .testimonials__track {
    display: flex;
    gap: var(--space-5);
    transition: transform 450ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials__track { transition: none; }
  }

  /* Testimonial card */
  .testimonial-card {
    flex-shrink: 0;
    width: calc(100% - var(--space-5));
    background-color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.06){% else %}var(--color-background){% endif %};
    padding: var(--space-8) var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: relative;
  }

  @media (min-width: 640px) {
    .testimonial-card { width: calc(50% - var(--space-3)); }
  }

  @media (min-width: 1024px) {
    .testimonial-card { width: calc(33.333% - var(--space-4)); }
  }

  /* Quote mark decoration */
  .testimonial-card::before {
    content: '\201C';
    position: absolute;
    top: var(--space-4);
    right: var(--space-6);
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.08){% else %}rgba(139,58,42,0.1){% endif %};
    pointer-events: none;
  }

  .testimonial-card__stars {
    display: flex;
    gap: 2px;
  }

  .testimonial-card__stars svg {
    width: 14px;
    height: 14px;
    color: #C8883A;
  }

  .testimonial-card__text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1.55;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.88){% else %}var(--color-foreground){% endif %};
    flex: 1;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border-top: 1px solid {% if section.settings.background == 'dark' %}rgba(255,255,255,0.1){% else %}var(--color-border){% endif %};
    padding-top: var(--space-4);
  }

  .testimonial-card__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-foreground);
    flex-shrink: 0;
    overflow: hidden;
  }

  .testimonial-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__name {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: {% if section.settings.background == 'dark' %}#fff{% else %}var(--color-foreground){% endif %};
    letter-spacing: 0.04em;
  }

  .testimonial-card__meta {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 300;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.4){% else %}rgba(44,26,14,0.45){% endif %};
    letter-spacing: 0.06em;
  }

  .testimonial-card__product {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  /* Nav dots + arrows */
  .testimonials__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .testimonials__arrow {
    width: 40px;
    height: 40px;
    border: 1.5px solid {% if section.settings.background == 'dark' %}rgba(255,255,255,0.25){% else %}var(--color-border){% endif %};
    background: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.6){% else %}rgba(44,26,14,0.5){% endif %};
    border-radius: 50%;
    transition: border-color var(--transition-base), color var(--transition-base);
  }

  .testimonials__arrow:hover {
    border-color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.7){% else %}var(--color-foreground){% endif %};
    color: {% if section.settings.background == 'dark' %}#fff{% else %}var(--color-foreground){% endif %};
  }

  .testimonials__arrow svg { width: 16px; height: 16px; }

  .testimonials__dots {
    display: flex;
    gap: var(--space-2);
  }

  .testimonials__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: {% if section.settings.background == 'dark' %}rgba(255,255,255,0.25){% else %}var(--color-border){% endif %};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .testimonials__dot.is-active {
    background-color: {% if section.settings.background == 'dark' %}#fff{% else %}var(--color-primary){% endif %};
    transform: scale(1.4);
  }
</style>

<section
  class="testimonials section-padding"
  id="Testimonials-{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Customer Reviews' }}"
>
  <div class="page-width">

    <div class="testimonials__header">
      <span class="eyebrow" style="color:{% if section.settings.background == 'dark' %}var(--color-secondary){% else %}var(--color-accent){% endif %}">
        {{ section.settings.eyebrow | default: 'Real Results' }}
      </span>
      <h2 class="testimonials__title">{{ section.settings.heading | default: 'She Grow is working.' }}</h2>
      <p class="testimonials__subtitle">{{ section.settings.subheading | default: 'From women who have done the work and seen the difference.' }}</p>
    </div>

    {%- if section.settings.show_aggregate -%}
      <div class="testimonials__aggregate">
        <span class="aggregate-score">{{ section.settings.aggregate_score | default: '4.9' }}</span>
        <div class="aggregate-details">
          {% render 'star-rating', rating: section.settings.aggregate_score | default: 4.9, review_count: section.settings.aggregate_count | default: 312, size: 'lg' %}
          <span class="aggregate-count">{{ section.settings.aggregate_count | default: '312' }} verified reviews</span>
        </div>
      </div>
    {%- endif -%}

    <div class="testimonials__track-wrap">
      <div class="testimonials__track" id="TestimonialsTrack-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial' -%}
            <article
              class="testimonial-card"
              id="TestimonialCard-{{ section.id }}-{{ forloop.index }}"
              {{ block.shopify_attributes }}
              aria-label="Review by {{ block.settings.reviewer_name | default: 'Customer' }}"
            >
              {%- if block.settings.product_name != blank -%}
                <span class="testimonial-card__product">{{ block.settings.product_name }}</span>
              {%- endif -%}

              <div class="testimonial-card__stars" aria-label="5 stars" role="img">
                {%- assign star_count = block.settings.star_rating | default: 5 -%}
                {%- for i in (1..star_count) -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                {%- endfor -%}
              </div>

              <blockquote class="testimonial-card__text">
                {{ block.settings.review_text | default: 'This product changed my hair routine completely.' }}
              </blockquote>

              <div class="testimonial-card__author">
                <div class="testimonial-card__avatar">
                  {%- if block.settings.reviewer_image != blank -%}
                    {{
                      block.settings.reviewer_image
                      | image_url: width: 72
                      | image_tag: alt: block.settings.reviewer_name, loading: 'lazy'
                    }}
                  {%- else -%}
                    {{ block.settings.reviewer_name | default: 'C' | truncate: 1, '' }}
                  {%- endif -%}
                </div>
                <div>
                  <p class="testimonial-card__name">{{ block.settings.reviewer_name | default: 'Customer' }}</p>
                  <p class="testimonial-card__meta">{{ block.settings.reviewer_meta | default: 'Verified buyer' }}</p>
                </div>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Nav -->
    <div class="testimonials__nav" role="group" aria-label="Review navigation">
      <button class="testimonials__arrow" id="TestimonialsPrev-{{ section.id }}" aria-label="Previous review">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <div class="testimonials__dots" id="TestimonialsDots-{{ section.id }}" role="list"></div>
      <button class="testimonials__arrow" id="TestimonialsNext-{{ section.id }}" aria-label="Next review">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

  </div>
</section>

<script>
(function() {
  var sId    = '{{ section.id }}';
  var track  = document.getElementById('TestimonialsTrack-' + sId);
  var prev   = document.getElementById('TestimonialsPrev-' + sId);
  var next   = document.getElementById('TestimonialsNext-' + sId);
  var dotsEl = document.getElementById('TestimonialsDots-' + sId);
  if (!track) return;

  var cards = track.querySelectorAll('.testimonial-card');
  var total = cards.length;
  var current = 0;

  function getVisible() {
    var w = window.innerWidth;
    if (w >= 1024) return 3;
    if (w >= 640) return 2;
    return 1;
  }

  function maxIndex() { return Math.max(0, total - getVisible()); }

  function buildDots() {
    dotsEl.innerHTML = '';
    for (var i = 0; i <= maxIndex(); i++) {
      var dot = document.createElement('button');
      dot.className = 'testimonials__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
      dot.dataset.index = i;
      dot.addEventListener('click', function() { goTo(parseInt(this.dataset.index, 10)); });
      dotsEl.appendChild(dot);
    }
  }

  function goTo(index) {
    current = Math.max(0, Math.min(index, maxIndex()));
    var cardWidth = cards[0] ? cards[0].offsetWidth + 20 : 0;
    track.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
    dotsEl.querySelectorAll('.testimonials__dot').forEach(function(d, i) {
      d.classList.toggle('is-active', i === current);
    });
  }

  if (prev) prev.addEventListener('click', function() { goTo(current - 1); });
  if (next) next.addEventListener('click', function() { goTo(current + 1); });

  buildDots();

  // Auto-advance
  {%- if section.settings.auto_advance -%}
  var autoTimer = setInterval(function() {
    goTo(current >= maxIndex() ? 0 : current + 1);
  }, {{ section.settings.auto_advance_speed | default: 5 | times: 1000 }});

  track.closest('.testimonials').addEventListener('mouseenter', function() { clearInterval(autoTimer); });
  {%- endif -%}

  window.addEventListener('resize', function() { buildDots(); goTo(current); });
})();
</script>

{% schema %}

{% comment %}
  sections/about.liquid
  She Grow Hair Co. — Brand Story / About Page Section
  Online Store 2.0 compatible
{% endcomment %}

<style>
  /* =============================================
     ABOUT PAGE — She Grow Hair Co.
     ============================================= */

  /* ---- Hero ---- */
  .about-hero {
    background-color: var(--color-foreground);
    position: relative;
    overflow: hidden;
    padding: var(--space-24) 0 var(--space-20);
  }

  .about-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: var(--space-5);
    display: block;
  }

  .about-hero__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 300;
    color: #fff;
    line-height: 1.05;
    max-width: 18ch;
    margin-bottom: var(--space-8);
  }

  .about-hero__heading em {
    font-style: italic;
    color: var(--color-secondary);
  }

  .about-hero__intro {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: 1.8;
    color: rgba(255,255,255,0.65);
    max-width: 52ch;
  }

  /* Decorative botanical line */
  .about-hero__deco {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 40%;
    background: linear-gradient(135deg,
      transparent 0%,
      rgba(139,58,42,0.08) 40%,
      rgba(90,107,71,0.12) 100%
    );
    pointer-events: none;
  }

  /* ---- Story Layout ---- */
  .about-story {
    background-color: var(--color-background);
  }

  .about-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 768px) {
    .about-story__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }

    .about-story__grid--reverse .about-story__image {
      order: 2;
    }

    .about-story__grid--reverse .about-story__text {
      order: 1;
    }
  }

  .about-story__image-wrap {
    position: relative;
  }

  .about-story__img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    display: block;
  }

  /* Offset accent block behind image */
  .about-story__image-wrap::before {
    content: '';
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    right: calc(var(--space-4) * -1);
    bottom: calc(var(--space-4) * -1);
    background-color: var(--color-surface);
    z-index: -1;
  }

  .about-story__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .about-story__heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.15;
    margin-bottom: var(--space-5);
  }

  .about-story__heading em {
    font-style: italic;
    color: var(--color-primary);
  }

  .about-story__body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.85;
    color: rgba(44,26,14,0.72);
  }

  .about-story__body p + p { margin-top: var(--space-4); }

  .about-story__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-top: var(--space-6);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: opacity var(--transition-base);
  }

  .about-story__link:hover { opacity: 0.65; }

  /* ---- Values grid ---- */
  .about-values {
    background-color: var(--color-surface);
  }

  .about-values__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .about-values__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--color-foreground);
    line-height: 1.15;
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 480px) {
    .about-values__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .about-values__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .value-card {
    padding: var(--space-8) var(--space-6);
    background-color: var(--color-background);
    border-top: 3px solid var(--color-primary);
  }

  .value-card__icon {
    font-size: 2rem;
    margin-bottom: var(--space-4);
    display: block;
    line-height: 1;
  }

  .value-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-foreground);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .value-card__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(44,26,14,0.65);
  }

  /* ---- Founder Quote ---- */
  .about-quote {
    background-color: var(--color-primary);
    padding: var(--space-20) 0;
    text-align: center;
  }

  .about-quote__mark {
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 0.5;
    color: rgba(255,255,255,0.2);
    margin-bottom: var(--space-6);
    display: block;
  }

  .about-quote__text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    color: #fff;
    line-height: 1.4;
    max-width: 28ch;
    margin: 0 auto var(--space-6);
  }

  .about-quote__attribution {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
  }

  /* ---- Ingredients Callout ---- */
  .about-ingredients {
    background-color: var(--color-background);
  }

  .about-ingredients__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .about-ingredients__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--color-foreground);
  }

  .about-ingredients__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .about-ingredients__grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-6); }
  }

  .ingredient-chip {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-5);
    background-color: var(--color-surface);
    border-left: 2px solid var(--color-accent);
  }

  .ingredient-chip__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-foreground);
  }

  .ingredient-chip__benefit {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    color: rgba(44,26,14,0.6);
    line-height: 1.5;
  }

  /* ---- CTA Banner ---- */
  .about-cta {
    background-color: var(--color-foreground);
    text-align: center;
    padding: var(--space-20) 0;
  }

  .about-cta__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    color: #fff;
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .about-cta__heading em {
    font-style: italic;
    color: var(--color-secondary);
  }

  .about-cta__sub {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    color: rgba(255,255,255,0.6);
    max-width: 44ch;
    margin: 0 auto var(--space-10);
    line-height: 1.75;
  }
</style>

<!-- ABOUT HERO -->
<section class="about-hero" aria-label="About She Grow Hair Co.">
  <div class="about-hero__deco" aria-hidden="true"></div>
  <div class="page-width">
    <span class="about-hero__eyebrow">Our Story</span>
    <h1 class="about-hero__heading">
      Rooted in <em>intention.</em><br>
      Grown with care.
    </h1>
    <p class="about-hero__intro">
      She Grow Hair Co. was born from a simple truth: your hair deserves formulas as complex and beautiful as the woman wearing it. We blend botanical science with deep cultural roots to create rituals that actually work.
    </p>
  </div>
</section>

<!-- STORY SECTION 1 -->
<section class="about-story section-padding" aria-label="Brand origin story">
  <div class="page-width">
    <div class="about-story__grid">
      <div class="about-story__image">
        <div class="about-story__image-wrap">
          {%- if section.settings.story_image_1 != blank -%}
            {{
              section.settings.story_image_1
              | image_url: width: 800
              | image_tag:
                class: 'about-story__img',
                alt: section.settings.story_image_1.alt | default: 'She Grow Hair Co. founder',
                loading: 'lazy'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'about-story__img' }}
          {%- endif -%}
        </div>
      </div>
      <div class="about-story__text">
        <span class="about-story__eyebrow">Where it began</span>
        <h2 class="about-story__heading">
          Hair care that <em>honors</em> your roots
        </h2>
        <div class="about-story__body">
          <p>
            {{ section.settings.story_body_1 | default: "She Grow Hair Co. started the way most great things do — with a problem that needed solving. After years of searching for products that truly understood textured hair, our founder took matters into her own hands. She studied botanical ingredients, spent months in her kitchen testing formulas, and listened deeply to the women in her community." }}
          </p>
          <p>
            {{ section.settings.story_body_2 | default: "What emerged wasn't just a product line — it was a philosophy. Hair health isn't about trends. It's about understanding your individual hair's needs, feeding it the right nutrients, and giving it the patience and ritual it deserves." }}
          </p>
        </div>
        <a href="/collections/all" class="about-story__link">Shop the collection →</a>
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="about-values section-padding" aria-label="Brand values">
  <div class="page-width">
    <div class="about-values__header">
      <span class="eyebrow">What we stand for</span>
      <h2 class="about-values__title">The She Grow Standard</h2>
    </div>
    <div class="about-values__grid">
      <div class="value-card">
        <span class="value-card__icon" aria-hidden="true">🌿</span>
        <h3 class="value-card__title">Botanical First</h3>
        <p class="value-card__body">Every formula leads with plant-based actives — cherry extract, castor oil, aloe, and green tea — chosen for what they do, not how they sound.</p>
      </div>
      <div class="value-card">
        <span class="value-card__icon" aria-hidden="true">🧪</span>
        <h3 class="value-card__title">Intentionally Formulated</h3>
        <p class="value-card__body">No sulfates. No parabens. No harsh fillers. Only ingredients that earn their place in every bottle by doing real work for your hair.</p>
      </div>
      <div class="value-card">
        <span class="value-card__icon" aria-hidden="true">🤍</span>
        <h3 class="value-card__title">For Every Texture</h3>
        <p class="value-card__body">Curls, coils, waves, locs — our formulas are designed for the full spectrum of Black and textured hair, because one formula does not fit all.</p>
      </div>
      <div class="value-card">
        <span class="value-card__icon" aria-hidden="true">🌍</span>
        <h3 class="value-card__title">Clean & Conscious</h3>
        <p class="value-card__body">Cruelty-free always. Sustainably sourced where possible. Packaging designed with the planet in mind. Because beauty shouldn't cost the earth.</p>
      </div>
    </div>
  </div>
</section>

<!-- FOUNDER QUOTE -->
<section class="about-quote" aria-label="Founder quote">
  <div class="page-width">
    <span class="about-quote__mark" aria-hidden="true">"</span>
    <blockquote class="about-quote__text">
      {{ section.settings.founder_quote | default: "I wanted to create something I wish I'd had — a line that sees my hair the way I see it. As something worth celebrating, not something to be managed." }}
    </blockquote>
    <p class="about-quote__attribution">
      {{ section.settings.founder_name | default: "— Founder, She Grow Hair Co." }}
    </p>
  </div>
</section>

<!-- INGREDIENTS SPOTLIGHT -->
<section class="about-ingredients section-padding" aria-label="Key ingredients">
  <div class="page-width">
    <div class="about-ingredients__header">
      <span class="eyebrow">Inside every bottle</span>
      <h2 class="about-ingredients__title">Ingredients that do the work</h2>
    </div>
    <div class="about-ingredients__grid">
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Cherry Extract</span>
        <p class="ingredient-chip__benefit">Antioxidant-rich detoxifier that draws out scalp buildup and boosts follicle health.</p>
      </div>
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Jamaican Black Castor Oil</span>
        <p class="ingredient-chip__benefit">Thickens strands, seals the cuticle, and supports growth from the root.</p>
      </div>
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Aloe Vera</span>
        <p class="ingredient-chip__benefit">Calms scalp inflammation and delivers instant, weightless hydration.</p>
      </div>
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Rosemary Oil</span>
        <p class="ingredient-chip__benefit">Clinically studied to stimulate follicles and improve density over time.</p>
      </div>
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Shea Butter</span>
        <p class="ingredient-chip__benefit">Locks in moisture, reduces breakage, and restores elasticity to dry strands.</p>
      </div>
      <div class="ingredient-chip">
        <span class="ingredient-chip__name">Green Tea</span>
        <p class="ingredient-chip__benefit">Fights DHT at the scalp level to support healthier, fuller-feeling hair.</p>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT CTA -->
<section class="about-cta" aria-label="Shop call to action">
  <div class="page-width">
    <h2 class="about-cta__heading">
      Ready to start your <em>ritual?</em>
    </h2>
    <p class="about-cta__sub">
      Four targeted formulas. Every strand type. One collection designed to take your hair from surviving to thriving.
    </p>
    <a href="/collections/all" class="btn btn-primary" style="background:#fff; color:var(--color-primary); border-color:#fff;">
      Shop She Grow
    </a>
  </div>
</section>

{% schema %}
{
  "name": "About Page",
  "tag": "div",
  "class": "about-page",
  "settings": [
    {
      "type": "image_picker",
      "id": "story_image_1",
      "label": "Story image",
      "info": "Portrait orientation recommended. 800px wide minimum."
    },
    {
      "type": "textarea",
      "id": "story_body_1",
      "label": "Story paragraph 1",
      "default": "She Grow Hair Co. started the way most great things do — with a problem that needed solving. After years of searching for products that truly understood textured hair, our founder took matters into her own hands."
    },
    {
      "type": "textarea",
      "id": "story_body_2",
      "label": "Story paragraph 2",
      "default": "What emerged wasn't just a product line — it was a philosophy. Hair health isn't about trends. It's about understanding your individual hair's needs, feeding it the right nutrients, and giving it the patience it deserves."
    },
    {
      "type": "textarea",
      "id": "founder_quote",
      "label": "Founder quote",
      "default": "I wanted to create something I wish I'd had — a line that sees my hair the way I see it. As something worth celebrating, not something to be managed."
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Quote attribution",
      "default": "— Founder, She Grow Hair Co."
    }
  ],
  "presets": [
    {
      "name": "About Page"
    }
  ]
}
{% endschema %}


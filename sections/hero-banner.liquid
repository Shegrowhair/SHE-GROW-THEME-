{% comment %}
  sections/hero-banner.liquid
  She Grow Hair Co. — Full-bleed Homepage Hero
  Online Store 2.0 compatible
{% endcomment %}

{%- liquid
  assign hero_image       = section.settings.hero_image
  assign heading_line1    = section.settings.heading_line1
  assign heading_line2    = section.settings.heading_line2
  assign subheading       = section.settings.subheading
  assign cta_label        = section.settings.cta_label
  assign cta_url          = section.settings.cta_url
  assign cta2_label       = section.settings.cta2_label
  assign cta2_url         = section.settings.cta2_url
  assign overlay_opacity  = section.settings.overlay_opacity
  assign text_position    = section.settings.text_position
  assign hero_height      = section.settings.hero_height
  assign show_scroll_cue  = section.settings.show_scroll_cue
-%}

<style>
  /* =============================================
     HERO BANNER — She Grow Hair Co.
     Signature element: the split italic/upright
     heading with an earthy botanical undertone.
     ============================================= */
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: {% if text_position == 'bottom' %}flex-end{% elsif text_position == 'center' %}center{% else %}flex-end{% endif %};

    {% if hero_height == 'full' %}
      height: 100svh;
      min-height: 560px;
    {% elsif hero_height == 'large' %}
      height: clamp(560px, 85vh, 900px);
    {% else %}
      height: clamp(480px, 70vh, 720px);
    {% endif %}
  }

  /* Background image */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Gradient overlay — bottom-weighted for text legibility */
  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(22, 10, 4, {{ overlay_opacity | divided_by: 100.0 | plus: 0.25 }}) 0%,
      rgba(22, 10, 4, {{ overlay_opacity | divided_by: 100.0 | times: 0.6 }}) 45%,
      rgba(22, 10, 4, 0.05) 100%
    );
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-16) var(--space-6) var(--space-16);
  }

  @media (min-width: 768px) {
    .hero__content {
      padding: var(--space-20) var(--space-10) var(--space-20);
    }
  }

  @media (min-width: 1024px) {
    .hero__content {
      padding: var(--space-24) var(--space-16) var(--space-24);
      max-width: 900px;
    }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-5);
  }

  .hero__eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background-color: rgba(255,255,255,0.5);
  }

  /* Signature heading: italic line 1, upright line 2 */
  .hero__heading {
    font-family: var(--font-display);
    font-weight: 300;
    line-height: 1.05;
    color: #fff;
    margin-bottom: var(--space-6);
  }

  .hero__heading-italic {
    display: block;
    font-style: italic;
    font-size: var(--text-hero);
    letter-spacing: -0.02em;
    color: rgba(255,255,255,0.92);
  }

  .hero__heading-upright {
    display: block;
    font-style: normal;
    font-size: clamp(1.5rem, 4vw, 2.75rem);
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-top: var(--space-2);
  }

  .hero__subheading {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    color: rgba(255,255,255,0.7);
    max-width: 44ch;
    line-height: 1.75;
    margin-bottom: var(--space-10);
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .hero__subheading { font-size: var(--text-lg); }
  }

  /* CTA group */
  .hero__cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }

  .hero__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background-color: #fff;
    color: var(--color-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: var(--space-4) var(--space-8);
    border: 1.5px solid #fff;
    text-decoration: none;
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .hero__btn-primary:hover {
    background-color: transparent;
    color: #fff;
  }

  .hero__btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background-color: transparent;
    color: rgba(255,255,255,0.85);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: var(--space-4) 0;
    border: none;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    transition: color var(--transition-base), border-color var(--transition-base);
  }

  .hero__btn-secondary:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.9);
  }

  /* Scroll cue */
  .hero__scroll-cue {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255,255,255,0.45);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    animation: scrollBounce 2s ease-in-out infinite;
  }

  .hero__scroll-cue svg {
    width: 18px;
    height: 18px;
  }

  @keyframes scrollBounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-cue { animation: none; }
  }

  /* Placeholder when no image set */
  .hero__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #3d1f0f 0%, #7a3520 40%, #5a4030 100%);
  }
</style>

<section class="hero" id="Hero-{{ section.id }}" aria-label="Homepage hero">

  <!-- Background -->
  <div class="hero__bg" aria-hidden="true">
    {%- if hero_image != blank -%}
      {{
        hero_image
        | image_url: width: 2000
        | image_tag:
          class: 'hero__bg-img',
          alt: hero_image.alt | default: shop.name,
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    {%- else -%}
      <div class="hero__placeholder"></div>
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>

  <!-- Content -->
  <div class="hero__content page-width">

    {%- for block in section.blocks -%}
      {%- if block.type == 'eyebrow' and block.settings.eyebrow_text != blank -%}
        <p class="hero__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.eyebrow_text }}</p>
      {%- endif -%}
    {%- endfor -%}

    {%- if heading_line1 != blank or heading_line2 != blank -%}
      <h1 class="hero__heading">
        {%- if heading_line1 != blank -%}
          <span class="hero__heading-italic">{{ heading_line1 }}</span>
        {%- endif -%}
        {%- if heading_line2 != blank -%}
          <span class="hero__heading-upright">{{ heading_line2 }}</span>
        {%- endif -%}
      </h1>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="hero__subheading">{{ subheading }}</p>
    {%- endif -%}

    {%- if cta_label != blank or cta2_label != blank -%}
      <div class="hero__cta-group">
        {%- if cta_label != blank -%}
          <a href="{{ cta_url | default: '/collections/all' }}" class="hero__btn-primary">
            {{ cta_label }}
          </a>
        {%- endif -%}
        {%- if cta2_label != blank -%}
          <a href="{{ cta2_url | default: '/pages/about' }}" class="hero__btn-secondary">
            {{ cta2_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>

  {%- if show_scroll_cue -%}
    <div class="hero__scroll-cue" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image",
      "info": "Recommended: 2000px wide, portrait or landscape. JPG for best performance."
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading — italic line",
      "default": "Grow into yourself."
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading — upright line",
      "default": "Root-deep hair rituals"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Botanical formulas crafted to nourish every curl, coil, and wave — from the follicle out."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Primary button text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button text",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 10,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Hero height",
      "options": [
        { "value": "full",   "label": "Full screen" },
        { "value": "large",  "label": "Large (85vh)" },
        { "value": "medium", "label": "Medium (70vh)" }
      ],
      "default": "full"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "Text vertical position",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow label",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "eyebrow_text",
          "label": "Eyebrow text",
          "default": "She Grow Hair Co."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "eyebrow",
          "settings": { "eyebrow_text": "She Grow Hair Co." }
        }
      ]
    }
  ]
}
{% endschema %}


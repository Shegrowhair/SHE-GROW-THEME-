{% comment %}
  sections/header.liquid
  She Grow Hair Co. — Navigation Header
  Online Store 2.0 compatible
{% endcomment %}

{%- liquid
  assign header_style     = section.settings.header_style
  assign sticky_header    = section.settings.sticky_header
  assign show_search      = section.settings.show_search
  assign show_cart_icon   = section.settings.show_cart_icon
  assign logo             = section.settings.logo
  assign logo_width       = section.settings.logo_width
  assign logo_width_mob   = section.settings.logo_width_mobile
  assign menu             = section.settings.menu
  assign cart_count       = cart.item_count
-%}

<style>
  /* =============================================
     HEADER — She Grow Hair Co.
     ============================================= */
  .site-header {
    position: relative;
    z-index: 100;
    background-color: {% if header_style == 'transparent' %}transparent{% else %}var(--color-background){% endif %};
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition-slow),
                box-shadow var(--transition-slow);
  }

  {% if sticky_header %}
  .site-header--sticky {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-header--scrolled {
    background-color: var(--color-background) !important;
    box-shadow: var(--shadow-sm);
  }
  {% endif %}

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 70px;
    gap: var(--space-4);
  }

  @media (min-width: 1024px) {
    .header-inner { height: 80px; }
  }

  /* ---- Logo ---- */
  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .header-logo img {
    width: {{ logo_width_mob }}px;
    height: auto;
    display: block;
  }

  @media (min-width: 1024px) {
    .header-logo img { width: {{ logo_width }}px; }
  }

  .header-logo__text {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--color-foreground);
    white-space: nowrap;
    text-decoration: none;
  }

  @media (min-width: 1024px) {
    .header-logo__text { font-size: var(--text-2xl); }
  }

  /* ---- Desktop Navigation ---- */
  .header-nav {
    display: none;
  }

  @media (min-width: 1024px) {
    .header-nav {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: var(--space-8);
    }
  }

  .header-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
  }

  .header-nav__item {
    position: relative;
  }

  .header-nav__link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-foreground);
    text-decoration: none;
    padding: var(--space-2) 0;
    position: relative;
  }

  .header-nav__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-primary);
    transition: width var(--transition-base);
  }

  .header-nav__link:hover::after,
  .header-nav__link--active::after {
    width: 100%;
  }

  /* ---- Dropdown ---- */
  .header-nav__dropdown {
    position: absolute;
    top: calc(100% + var(--space-4));
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    min-width: 220px;
    padding: var(--space-3) 0;
    box-shadow: var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-base), visibility var(--transition-base), transform var(--transition-base);
    transform: translateX(-50%) translateY(8px);
    z-index: 200;
  }

  .header-nav__item:hover .header-nav__dropdown,
  .header-nav__item:focus-within .header-nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .header-nav__dropdown-link {
    display: block;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-foreground);
    letter-spacing: 0.04em;
    transition: color var(--transition-base), background-color var(--transition-base);
  }

  .header-nav__dropdown-link:hover {
    color: var(--color-primary);
    background-color: var(--color-surface);
  }

  /* ---- Header Utilities (icons) ---- */
  .header-utils {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-3);
  }

  .header-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    position: relative;
    color: var(--color-foreground);
    transition: color var(--transition-base);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .header-icon-btn:hover {
    color: var(--color-primary);
  }

  .header-icon-btn svg {
    width: 20px;
    height: 20px;
    stroke-width: 1.5;
  }

  /* ---- Mobile Menu Button ---- */
  .header-burger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .header-burger { display: none; }
  }

  .header-burger__line {
    width: 22px;
    height: 1.5px;
    background-color: var(--color-foreground);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  /* ---- Mobile Drawer ---- */
  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 300;
    visibility: hidden;
    pointer-events: none;
  }

  .mobile-nav.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(44, 26, 14, 0.5);
    opacity: 0;
    transition: opacity var(--transition-slow);
    cursor: pointer;
  }

  .mobile-nav.is-open .mobile-nav__overlay {
    opacity: 1;
  }

  .mobile-nav__drawer {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(85vw, 360px);
    background-color: var(--color-background);
    padding: var(--space-8) var(--space-6);
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform var(--transition-slow);
  }

  .mobile-nav.is-open .mobile-nav__drawer {
    transform: translateX(0);
  }

  .mobile-nav__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-8);
  }

  .mobile-nav__logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    color: var(--color-foreground);
    letter-spacing: 0.04em;
  }

  .mobile-nav__close {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--color-border);
    cursor: pointer;
    color: var(--color-foreground);
    border-radius: var(--border-radius);
  }

  .mobile-nav__list {
    list-style: none;
  }

  .mobile-nav__item {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-nav__link {
    display: block;
    padding: var(--space-4) 0;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-foreground);
    transition: color var(--transition-base);
  }

  .mobile-nav__link:hover {
    color: var(--color-primary);
  }

  .mobile-nav__sub {
    padding-bottom: var(--space-3);
    list-style: none;
  }

  .mobile-nav__sub a {
    display: block;
    padding: var(--space-2) 0 var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    color: rgba(44,26,14,0.65);
    transition: color var(--transition-base);
  }

  .mobile-nav__sub a:hover {
    color: var(--color-primary);
  }

  /* ---- Search Overlay ---- */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 400;
    background-color: rgba(44,26,14,0.6);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-base), visibility var(--transition-base);
  }

  .search-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .search-overlay__box {
    background-color: var(--color-background);
    padding: var(--space-8);
    width: min(90vw, 600px);
    box-shadow: var(--shadow-lg);
  }

  .search-overlay__label {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    color: var(--color-foreground);
    margin-bottom: var(--space-6);
    display: block;
  }

  .search-overlay__form {
    display: flex;
    gap: var(--space-2);
    border-bottom: 2px solid var(--color-foreground);
    padding-bottom: var(--space-3);
  }

  .search-overlay__input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-foreground);
    padding: 0;
  }

  .search-overlay__input::placeholder {
    color: rgba(44,26,14,0.35);
  }

  .search-overlay__close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-xl);
    color: rgba(44,26,14,0.5);
    padding: 0;
    transition: color var(--transition-base);
  }

  .search-overlay__close:hover {
    color: var(--color-foreground);
  }
</style>

<header class="site-header{% if sticky_header %} site-header--sticky{% endif %}" id="SiteHeader" role="banner">
  <div class="page-width">
    <div class="header-inner">

      <!-- Left: Burger + Desktop Nav -->
      <div>
        {%- if menu != blank -%}
          <!-- Mobile Burger -->
          <button
            class="header-burger"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="MobileNav"
            id="BurgerBtn"
          >
            <span class="header-burger__line"></span>
            <span class="header-burger__line"></span>
            <span class="header-burger__line"></span>
          </button>

          <!-- Desktop Nav -->
          <nav class="header-nav" role="navigation" aria-label="Main navigation">
            <ul class="header-nav__list">
              {%- for link in linklists[menu].links -%}
                <li class="header-nav__item">
                  <a
                    href="{{ link.url }}"
                    class="header-nav__link{% if link.active %} header-nav__link--active{% endif %}"
                    {% if link.active %}aria-current="page"{% endif %}
                  >
                    {{ link.title }}
                  </a>
                  {%- if link.links.size > 0 -%}
                    <ul class="header-nav__dropdown" role="list">
                      {%- for child_link in link.links -%}
                        <li>
                          <a
                            href="{{ child_link.url }}"
                            class="header-nav__dropdown-link"
                            {% if child_link.active %}aria-current="page"{% endif %}
                          >
                            {{ child_link.title }}
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      </div>

      <!-- Center: Logo -->
      <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }} — return to homepage">
        {%- if logo != blank -%}
          {{
            logo
            | image_url: width: logo_width
            | image_tag:
              width: logo_width,
              height: 'auto',
              alt: shop.name,
              class: 'header-logo__img',
              loading: 'eager'
          }}
        {%- else -%}
          <span class="header-logo__text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Right: Utility Icons -->
      <div class="header-utils">
        {%- if show_search -%}
          <button
            class="header-icon-btn"
            aria-label="Search"
            aria-expanded="false"
            aria-controls="SearchOverlay"
            id="SearchBtn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M16.65 10.8a6.85 6.85 0 11-13.7 0 6.85 6.85 0 0113.7 0z"/>
            </svg>
          </button>
        {%- endif -%}

        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header-icon-btn"
            aria-label="{%- if customer -%}My account{%- else -%}Log in{%- endif -%}"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.5 20.25a8.25 8.25 0 0115 0"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if show_cart_icon -%}
          <a
            href="{{ routes.cart_url }}"
            class="header-icon-btn"
            aria-label="Cart ({{ cart.item_count }} items)"
            id="CartIconBtn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
            </svg>
            {%- if cart_count > 0 -%}
              <span class="cart-count-bubble" aria-hidden="true">{{ cart_count }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</header>

<!-- Mobile Navigation Drawer -->
{%- if menu != blank -%}
  <div
    class="mobile-nav"
    id="MobileNav"
    aria-modal="true"
    role="dialog"
    aria-label="Navigation menu"
    aria-hidden="true"
  >
    <div class="mobile-nav__overlay" id="MobileNavOverlay" aria-hidden="true"></div>
    <div class="mobile-nav__drawer">
      <div class="mobile-nav__header">
        <span class="mobile-nav__logo">{{ shop.name }}</span>
        <button class="mobile-nav__close" id="MobileNavClose" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <ul class="mobile-nav__list" role="list">
        {%- for link in linklists[menu].links -%}
          <li class="mobile-nav__item">
            <a
              href="{{ link.url }}"
              class="mobile-nav__link"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
            {%- if link.links.size > 0 -%}
              <ul class="mobile-nav__sub">
                {%- for child_link in link.links -%}
                  <li>
                    <a href="{{ child_link.url }}" {% if child_link.active %}aria-current="page"{% endif %}>
                      {{ child_link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
{%- endif -%}

<!-- Search Overlay -->
{%- if show_search -%}
  <div class="search-overlay" id="SearchOverlay" role="dialog" aria-modal="true" aria-label="Search" aria-hidden="true">
    <div class="search-overlay__box">
      <label class="search-overlay__label" for="SearchInput">What are you looking for?</label>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-overlay__form">
        <input
          id="SearchInput"
          type="search"
          name="q"
          class="search-overlay__input"
          placeholder="Cherry Detox, Follicle Oil…"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
        >
        <button class="search-overlay__close" id="SearchClose" type="button" aria-label="Close search">&#10005;</button>
      </form>
    </div>
  </div>
{%- endif -%}

<script>
  (function () {
    // Sticky scroll effect
    {% if sticky_header %}
    var header = document.getElementById('SiteHeader');
    if (header) {
      window.addEventListener('scroll', function () {
        header.classList.toggle('site-header--scrolled', window.scrollY > 10);
      }, { passive: true });
    }
    {% endif %}

    // Mobile nav
    var burgerBtn     = document.getElementById('BurgerBtn');
    var mobileNav     = document.getElementById('MobileNav');
    var mobileClose   = document.getElementById('MobileNavClose');
    var mobileOverlay = document.getElementById('MobileNavOverlay');

    function openMobileNav() {
      if (!mobileNav) return;
      mobileNav.classList.add('is-open');
      mobileNav.setAttribute('aria-hidden', 'false');
      if (burgerBtn) burgerBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileNav() {
      if (!mobileNav) return;
      mobileNav.classList.remove('is-open');
      mobileNav.setAttribute('aria-hidden', 'true');
      if (burgerBtn) burgerBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    if (burgerBtn)     burgerBtn.addEventListener('click', openMobileNav);
    if (mobileClose)   mobileClose.addEventListener('click', closeMobileNav);
    if (mobileOverlay) mobileOverlay.addEventListener('click', closeMobileNav);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeMobileNav();
        closeSearch();
      }
    });

    // Search overlay
    var searchBtn     = document.getElementById('SearchBtn');
    var searchOverlay = document.getElementById('SearchOverlay');
    var searchClose   = document.getElementById('SearchClose');
    var searchInput   = document.getElementById('SearchInput');

    function openSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.add('is-open');
      searchOverlay.setAttribute('aria-hidden', 'false');
      if (searchBtn) searchBtn.setAttribute('aria-expanded', 'true');
      setTimeout(function () { if (searchInput) searchInput.focus(); }, 50);
    }

    function closeSearch() {
      if (!searchOverlay) return;
      searchOverlay.classList.remove('is-open');
      searchOverlay.setAttribute('aria-hidden', 'true');
      if (searchBtn) searchBtn.setAttribute('aria-expanded', 'false');
    }

    if (searchBtn) searchBtn.addEventListener('click', openSearch);
    if (searchClose) searchClose.addEventListener('click', closeSearch);
    if (searchOverlay) {
      searchOverlay.addEventListener('click', function (e) {
        if (e.target === searchOverlay) closeSearch();
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (desktop)",
      "min": 80,
      "max": 320,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo width (mobile)",
      "min": 60,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main navigation menu",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "header_style",
      "label": "Header background",
      "options": [
        { "value": "solid",       "label": "Solid" },
        { "value": "transparent", "label": "Transparent (hero overlap)" }
      ],
      "default": "solid"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky on scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart_icon",
      "label": "Show cart icon",
      "default": true
    }
  ]
}
{% endschema %}

